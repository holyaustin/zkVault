# Copy to .env at the workspace root. Used by anything built with
# --features livenet (currently: contract/src/bin/check_eligibility.rs).
# Variable names follow Odra's own convention -- see
# https://odra.dev/docs/backends/livenet/

# Path to a funded testnet account's secret key (.pem). Read-only view
# calls don't spend gas, but Odra's livenet env still wants a configured
# signer.
ODRA_CASPER_LIVENET_SECRET_KEY_PATH=./keys/testnet_secret_key.pem

# For CSPR.cloud: https://node.testnet.cspr.cloud
# Or your own testnet node's RPC address.
ODRA_CASPER_LIVENET_NODE_ADDRESS=https://node.testnet.casper.network:7777

ODRA_CASPER_LIVENET_CHAIN_NAME=casper-test

# Optional, only needed if you use Odra's event-streaming helpers.
# ODRA_CASPER_LIVENET_EVENTS_URL=https://node.testnet.cspr.cloud/events
