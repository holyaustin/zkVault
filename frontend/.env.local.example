# Copy to .env.local in frontend/

# Get your own at https://console.cspr.build after registering an app.
# The default 'csprclick-template' (used if this is unset) only works for
# local development.
NEXT_PUBLIC_CSPRCLICK_APP_ID=csprclick-template

NEXT_PUBLIC_CASPER_NODE_URL=https://node.testnet.casper.network:7777/rpc
NEXT_PUBLIC_CASPER_CHAIN_NAME=casper-test

# Set after running ../scripts/deploy_testnet.sh
NEXT_PUBLIC_ZKVAULT_CONTRACT_HASH=hash-...

# Server-side only (used by app/api/eligibility/route.ts as a fallback
# when the client doesn't pass ?contract=). Same value as above is fine.
ZKVAULT_CONTRACT_HASH=hash-...

# Only needed if this frontend's working directory isn't one level above
# the Cargo workspace root (see app/api/prove/route.ts and
# app/api/eligibility/route.ts).
# WORKSPACE_ROOT=/absolute/path/to/zkvault-hackathon
